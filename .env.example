# GLOF Early Warning System — Environment Variables
# Copy this file to backend/.env and fill in real values.

# ── Required in production ───────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-string

# ── Database ─────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/glof_db
REDIS_HOST=localhost
REDIS_PORT=6379

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins (use * only for dev)
CORS_ORIGINS=http://localhost:3000

# ── Flask ────────────────────────────────────────────────
FLASK_ENV=development     # set to "production" on deployment

# ── Alert tuning ─────────────────────────────────────────
ALERT_COOLDOWN_SECONDS=900

# ── Sensor auth (HMAC) ───────────────────────────────────
SENSOR_API_KEY=glof-sensor-secret-key-2024

# ── Email (Resend) ───────────────────────────────────────
# Optional — leave empty to disable email notifications
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# ── ML model blend (0.0 = formula only, 1.0 = ML only) ──
ML_BLEND_RATIO=0.4
